  <!-- Example 31: Ordered list -->
  <list class="ordered">
    <ldiv><marker>1.</marker></ldiv>
    <text>Install dependencies</text>
    <ldiv><marker>2.</marker></ldiv>
    <text>Run tests</text>
    <ldiv><marker>3.</marker></ldiv>
    <text>Deploy application</text>
  </list>

  <!-- Example 32: List with empty ldiv (no marker) -->
  <list class="unordered">
    <ldiv/>
    <text>Item without visible marker</text>
    <ldiv/>
    <text>Another item without marker</text>
  </list>

  <!-- Example 32b: List with element head (aligns with table validation) -->
  <list class="unordered">
    <location value="10"/>
    <location value="100"/>
    <location value="200"/>
    <location value="150"/>
    <ldiv><marker>•</marker></ldiv>
    <text>First item with metadata</text>
    <ldiv><marker>•</marker></ldiv>
    <text>Second item with metadata</text>
  </list>

  <!-- Example 33: Nested lists (ordered and unordered) -->
  <list class="ordered">
    <ldiv><marker>1.</marker></ldiv>
    <text>Setup project</text>
    <list class="unordered">
      <ldiv><marker>•</marker></ldiv>
      <text>Create virtual environment</text>
      <ldiv><marker>•</marker></ldiv>
      <text>Configure linter</text>
    </list>
    <ldiv><marker>2.</marker></ldiv>
    <text>Implement features</text>
  </list>

  <!-- Example 34: List with checkbox markers -->
  <list class="unordered">
    <ldiv><marker><checkbox class="selected"/></marker></ldiv>
    <text>Completed task</text>
    <ldiv><marker><checkbox class="unselected"/></marker></ldiv>
    <text>Pending task</text>
    <ldiv><marker><checkbox/></marker></ldiv>
    <text>Another pending task (default unselected)</text>
  </list>

  <!-- Example 35: List with formatted markers -->
