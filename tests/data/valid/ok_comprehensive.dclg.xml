  <text>
    1<superscript>st</superscript> thing to remember: drink H<subscript>2</subscript>O.
  </text>

  <!-- Example 28: List with caption in element head -->
  <list class="unordered">
    <caption>List caption</caption>
    <ldiv><marker>•</marker></ldiv>
    <text>First item</text>
    <ldiv><marker>•</marker></ldiv>
    <text>Second item</text>
  </list>

  <!-- Example 29: Text with element head -->
  <text>
    Text with metadata
    <code>inline code and formula NOK</code>
    <code><![CDATA[<bold>print("hi")</bold>]]></code>
    <code><![CDATA[<bold>print("hi")</bold>]]></code>
  </text>

  <!-- Example 30: List with inline stuff -->
  <list class="unordered">
    <ldiv><marker>•</marker></ldiv>
